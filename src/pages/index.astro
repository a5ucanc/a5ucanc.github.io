---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="GHOSTWIRE">
  <div class="home">
    <div class="home-inner">
      <section class="hero">
        <p class="prompt"><span class="ps">$</span> whoami</p>
        <h1>GHOSTWIRE</h1>
        <p class="sub">
          Offensive security research — exploit development, red team tradecraft,
          malware analysis, and operational notes from the wire.
        </p>
      </section>
      <section class="recent">
        <h2 class="section-label"><span class="c">// </span>recent posts</h2>
        {posts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.id}
            tags={post.data.tags}
          />
        ))}
        <a href="/blog" class="all-posts">view all posts →</a>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .home { padding: 3rem 1rem; }
  .home-inner { max-width: var(--max-content-width); margin: 0 auto; }
  .hero { margin-bottom: 4rem; padding-bottom: 2rem; border-bottom: 1px solid var(--color-border-subtle); }
  .prompt { font-family: var(--font-mono); font-size: 0.85rem; color: var(--color-text-muted); margin-bottom: 1rem; }
  .ps { color: var(--color-accent-primary); margin-right: 0.5em; }
  h1 { font-family: var(--font-mono); font-size: 2.5rem; font-weight: 600; letter-spacing: -0.03em; color: var(--color-accent-primary); margin-bottom: 1rem; }
  .sub { color: var(--color-text-secondary); font-size: 0.95rem; line-height: 1.7; max-width: 520px; }
  .section-label { font-family: var(--font-mono); font-size: 0.85rem; color: var(--color-text-muted); margin-bottom: 1.5rem; font-weight: 400; }
  .c { color: var(--color-border-default); }
  .all-posts { display: inline-block; margin-top: 2rem; font-size: 0.875rem; color: var(--color-text-muted); }
  .all-posts:hover { color: var(--color-accent-primary); text-decoration: none; }
</style>
