---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const allTags = [...new Set(posts.flatMap((p) => p.data.tags))];
  return allTags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`#${tag}`} description={`Posts tagged ${tag}`}>
  <div class="tag-index">
    <div class="tag-inner">
      <header class="tag-header">
        <a href="/blog" class="back">← all posts</a>
        <h1><span class="c">// </span>#{tag}</h1>
        <p class="count">{posts.length} post{posts.length !== 1 ? 's' : ''}</p>
      </header>
      {posts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          slug={post.id}
          tags={post.data.tags}
        />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .tag-index { padding: 3rem 1rem; }
  .tag-inner { max-width: var(--max-content-width); margin: 0 auto; }
  .tag-header { margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 1px solid var(--color-border-subtle); }
  .back { font-size: 0.8rem; color: var(--color-text-muted); text-decoration: none; display: inline-block; margin-bottom: 1rem; }
  .back:hover { color: var(--color-accent-primary-dim); text-decoration: none; }
  h1 { font-family: var(--font-mono); font-size: 1.4rem; font-weight: 600; color: var(--color-text-primary); margin-bottom: 0.5rem; }
  .c { color: var(--color-text-muted); }
  .count { font-size: 0.8rem; color: var(--color-text-muted); }
</style>
