---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog" description="All offensive security research posts.">
  <div class="blog-index">
    <div class="blog-inner">
      <header class="blog-header">
        <h1><span class="c">// </span>all posts</h1>
        <p class="count">{posts.length} posts</p>
      </header>
      {posts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          slug={post.id}
          tags={post.data.tags}
          difficulty={post.data.difficulty}
        />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .blog-index { padding: 3rem 1rem; }
  .blog-inner { max-width: var(--max-content-width); margin: 0 auto; }
  .blog-header { margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 1px solid var(--color-border-subtle); display: flex; align-items: baseline; justify-content: space-between; }
  h1 { font-family: var(--font-mono); font-size: 1.4rem; font-weight: 600; color: var(--color-text-primary); }
  .c { color: var(--color-text-muted); }
  .count { font-size: 0.8rem; color: var(--color-text-muted); }
</style>
