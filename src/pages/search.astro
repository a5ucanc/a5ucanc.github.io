---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((p) => ({
    title: p.data.title,
    description: p.data.description,
    tags: p.data.tags,
    slug: p.id,
    pubDate: p.data.pubDate.toISOString().slice(0, 10),
  }));

const postsJson = JSON.stringify(allPosts);
---

<BaseLayout title="Search" description="Search all posts">
  <div class="search-page">
    <div class="search-inner">
      <header class="search-header">
        <h1><span class="c">// </span>search</h1>
      </header>
      <div class="search-box">
        <span class="search-prompt">$</span>
        <input
          id="search-input"
          type="text"
          placeholder="type to search..."
          autocomplete="off"
          autofocus
        />
      </div>
      <div id="search-status" class="search-hint">// all posts — start typing to filter</div>
      <div id="search-results"></div>
    </div>
  </div>

  <!-- Step 1: expose server data to client -->
  <script define:vars={{ postsJson }}>
    window.__POSTS__ = JSON.parse(postsJson);
  </script>

  <!-- Step 2: fuzzy search logic using DOM APIs only (no innerHTML with dynamic data) -->
  <script>
    import Fuse from 'fuse.js';

  const posts = window.__POSTS__;
  const fuse = new Fuse(posts, {
    keys: [
      { name: 'title', weight: 0.5 },
      { name: 'description', weight: 0.3 },
      { name: 'tags', weight: 0.2 },
    ],
    threshold: 0.4,
    includeScore: true,
    minMatchCharLength: 2,
  });

  const input = document.getElementById('search-input');
  const statusEl = document.getElementById('search-status');
  const resultsEl = document.getElementById('search-results');

  function makePostCard(post) {
    const article = document.createElement('article');
    article.className = 'result-card';

    const meta = document.createElement('div');
    meta.className = 'result-meta';
    const time = document.createElement('time');
    time.className = 'result-date';
    time.textContent = post.pubDate;
    meta.appendChild(time);
    article.appendChild(meta);

    const h2 = document.createElement('h2');
    h2.className = 'result-title';
    const link = document.createElement('a');
    link.href = '/blog/' + post.slug;
    link.textContent = post.title;
    h2.appendChild(link);
    article.appendChild(h2);

    const desc = document.createElement('p');
    desc.className = 'result-desc';
    desc.textContent = post.description;
    article.appendChild(desc);

    if (post.tags.length > 0) {
      const tagsDiv = document.createElement('div');
      tagsDiv.className = 'result-tags';
      post.tags.forEach((tag) => {
        const a = document.createElement('a');
        a.href = '/blog/tags/' + tag;
        a.className = 'tag';
        a.textContent = '#' + tag;
        tagsDiv.appendChild(a);
      });
      article.appendChild(tagsDiv);
    }

    return article;
  }

  function renderAll() {
    resultsEl.textContent = '';
    posts.forEach((post) => resultsEl.appendChild(makePostCard(post)));
  }

  renderAll();

  input.addEventListener('input', () => {
    const query = input.value.trim();
    resultsEl.textContent = '';

    if (!query) {
      statusEl.textContent = '// all posts — start typing to filter';
      renderAll();
      return;
    }

    const results = fuse.search(query);
    if (results.length === 0) {
      statusEl.textContent = '// no results found';
    } else {
      statusEl.textContent = '// ' + results.length + ' result' + (results.length !== 1 ? 's' : '');
      results.forEach((r) => resultsEl.appendChild(makePostCard(r.item)));
    }
  });
  </script>
</BaseLayout>

<style>
  .search-page { padding: 3rem 1rem; }
  .search-inner { max-width: var(--max-content-width); margin: 0 auto; }
  .search-header { margin-bottom: 2rem; }
  h1 { font-family: var(--font-mono); font-size: 1.4rem; font-weight: 600; color: var(--color-text-primary); }
  .c { color: var(--color-text-muted); }

  .search-box {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    border: 1px solid var(--color-border-default);
    border-radius: 4px;
    padding: 0.75rem 1rem;
    background: var(--color-bg-surface);
    margin-bottom: 1.5rem;
    transition: border-color 0.15s;
  }
  .search-box:focus-within { border-color: var(--color-accent-primary-muted); }
  .search-prompt { color: var(--color-accent-primary); font-family: var(--font-mono); font-size: 0.9rem; user-select: none; }
  #search-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: var(--color-text-primary);
    font-family: var(--font-mono);
    font-size: 0.95rem;
    caret-color: var(--color-accent-primary);
  }
  #search-input::placeholder { color: var(--color-text-muted); }

  .search-hint { font-size: 0.8rem; color: var(--color-text-muted); margin-bottom: 1.5rem; }

  .result-card { padding: 1.5rem 0; border-bottom: 1px solid var(--color-border-subtle); }
  .result-card:last-child { border-bottom: none; }
  .result-meta { margin-bottom: 0.5rem; }
  .result-date { font-size: 0.8rem; color: var(--color-text-muted); font-family: var(--font-mono); }
  .result-title { font-family: var(--font-mono); font-size: 1.1rem; font-weight: 600; margin-bottom: 0.5rem; line-height: 1.4; }
  .result-title a { color: var(--color-text-primary); text-decoration: none; transition: color 0.15s; }
  .result-title a:hover { color: var(--color-accent-primary); }
  .result-desc { font-size: 0.9rem; color: var(--color-text-muted); line-height: 1.6; margin-bottom: 0.5rem; }
  .result-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .tag { font-size: 0.75rem; color: var(--color-text-muted); font-family: var(--font-mono); text-decoration: none; }
  .tag:hover { color: var(--color-accent-primary-dim); }
</style>
