---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <p class="footer-copy"><span class="c">// </span>a5ucanc &mdash; {year}</p>
    <p class="footer-note"><span class="c">// </span>offensive security research</p>
  </div>
</footer>

<style>
  .site-footer { border-top: 1px solid var(--color-border-subtle); padding: 1.5rem 1rem; margin-top: 4rem; }
  .footer-inner { max-width: var(--max-site-width); margin: 0 auto; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.75rem; }
  .footer-copy, .footer-note { font-size: 0.8rem; color: var(--color-text-muted); font-family: var(--font-mono); }
  .c { color: var(--color-border-default); }
</style>
