---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags?: string[];
  difficulty?: string;
}
const { title, description, pubDate, slug, tags = [], difficulty } = Astro.props;
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit' });
---

<article class="post-card">
  <div class="card-meta">
    <time datetime={pubDate.toISOString()} class="card-date">{fmt(pubDate)}</time>
    {difficulty && <span class="card-diff" data-level={difficulty}>{difficulty}</span>}
  </div>
  <h2 class="card-title">
    <a href={`/blog/${slug}`}>{title}</a>
  </h2>
  <p class="card-desc">{description}</p>
  {tags.length > 0 && (
    <div class="card-tags">
      {tags.slice(0, 5).map((tag) => <span class="tag">#{tag}</span>)}
    </div>
  )}
</article>

<style>
  .post-card { padding: 1.5rem 0; border-bottom: 1px solid var(--color-border-subtle); }
  .post-card:last-child { border-bottom: none; }
  .card-meta { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; }
  .card-date { font-size: 0.8rem; color: var(--color-text-muted); font-family: var(--font-mono); }
  .card-diff { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.06em; padding: 0.1em 0.45em; border-radius: 2px; }
  .card-diff[data-level="advanced"] { background: var(--color-accent-threat-ghost); color: var(--color-accent-threat); }
  .card-diff[data-level="intermediate"] { background: var(--color-accent-intel-ghost); color: var(--color-accent-intel); }
  .card-diff[data-level="beginner"] { background: var(--color-accent-primary-ghost); color: var(--color-accent-primary); }
  .card-title { font-family: var(--font-mono); font-size: 1.1rem; font-weight: 600; margin-bottom: 0.5rem; line-height: 1.4; }
  .card-title a { color: var(--color-text-primary); text-decoration: none; transition: color 0.15s; }
  .card-title a:hover { color: var(--color-accent-primary); }
  .card-desc { font-size: 0.9rem; color: var(--color-text-muted); line-height: 1.6; margin-bottom: 0.75rem; }
  .card-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .tag { font-size: 0.75rem; color: var(--color-text-muted); font-family: var(--font-mono); }
</style>
