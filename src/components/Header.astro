---
const navLinks = [
  { href: '/', label: 'home' },
  { href: '/blog', label: 'blog' },
];

const path = Astro.url.pathname;
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo">
      <span class="lb">[</span>GHOSTWIRE<span class="lb">]</span>
    </a>
    <nav class="nav" aria-label="Main navigation">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={['nav-link', { active: path === href || (href !== '/' && path.startsWith(href)) }]}
        >
          {label}
        </a>
      ))}
      <button id="search-btn" class="nav-search-btn" aria-label="Search (press / or Ctrl+K)" title="Search">
        search<kbd class="nav-kbd">/</kbd>
      </button>
    </nav>
  </div>
</header>

<script>
  document.getElementById('search-btn')?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('search:open'));
  });
</script>

<script>
  const header = document.querySelector('.site-header') as HTMLElement;
  function updateNav() {
    header.classList.toggle('scrolled', window.scrollY > 20);
  }
  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition: background 0.25s, border-color 0.25s, backdrop-filter 0.25s;
  }
  .site-header.scrolled {
    background: rgba(26, 24, 20, 0.82);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .header-inner {
    max-width: var(--max-site-width);
    margin: 0 auto;
    padding: 0.9rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-primary);
    text-decoration: none;
    letter-spacing: 0.05em;
  }
  .lb { color: var(--color-accent-primary); }

  .nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .nav-link:hover,
  .nav-link.active { color: var(--color-accent-primary); }

  .nav-search-btn {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    transition: color 0.15s;
  }
  .nav-search-btn:hover { color: var(--color-accent-primary); }

  .nav-kbd {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border-default);
    border-radius: 3px;
    padding: 0.1em 0.35em;
  }
  .nav-search-btn:hover .nav-kbd { border-color: var(--color-accent-primary-muted); }
</style>
