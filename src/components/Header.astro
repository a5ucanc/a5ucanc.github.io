---
const navLinks = [
  { href: '/', label: 'home' },
  { href: '/blog', label: 'blog' },
];
const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="site-logo">
      <span class="lb">[</span>ghostwire<span class="lb">]</span>
    </a>
    <nav aria-label="Main navigation">
      {navLinks.map(({ href, label }) => (
        <a href={href} class:list={['nav-link', { active: currentPath === href || (href !== '/' && currentPath.startsWith(href)) }]}>
          {label}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-header { border-bottom: 1px solid var(--color-border-subtle); background-color: var(--color-bg-void); position: sticky; top: 0; z-index: 100; }
  .header-inner { max-width: var(--max-site-width); margin: 0 auto; padding: 1rem 1.5rem; display: flex; align-items: center; justify-content: space-between; }
  .site-logo { font-family: var(--font-mono); font-weight: 600; font-size: 1.05rem; color: var(--color-text-primary); text-decoration: none; letter-spacing: -0.02em; }
  .site-logo:hover { text-decoration: none; color: var(--color-text-primary); }
  .lb { color: var(--color-accent-primary); }
  nav { display: flex; gap: 1.5rem; }
  .nav-link { font-family: var(--font-mono); font-size: 0.875rem; color: var(--color-text-muted); text-decoration: none; transition: color 0.15s; }
  .nav-link:hover { color: var(--color-text-primary); text-decoration: none; }
  .nav-link.active { color: var(--color-accent-primary); }
</style>
