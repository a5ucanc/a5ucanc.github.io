---
import BaseLayout from './BaseLayout.astro';
import TagBadge from '../components/TagBadge.astro';
import '../styles/prose.css';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  headings?: { depth: number; slug: string; text: string }[];
}

const { title, description, pubDate, updatedDate, tags = [], headings = [] } = Astro.props;
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
const showToc = tocHeadings.length >= 2;
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={title} description={description} ogType="article">
  <article class="post">
    <header class="post-header">
      <div class="post-meta">
        <time datetime={pubDate.toISOString()}>{fmt(pubDate)}</time>
        {updatedDate && <span class="updated">— updated <time datetime={updatedDate.toISOString()}>{fmt(updatedDate)}</time></span>}
      </div>
      <h1 class="post-title">{title}</h1>
      <p class="post-description">{description}</p>
      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map((tag) => <TagBadge tag={tag} />)}
        </div>
      )}
    </header>
    <div class="prose">
      <slot />
    </div>
    <nav id="toc" aria-label="Table of contents" class:list={[{ 'toc-ready': showToc }]}>
      {showToc && (
        <>
          <div class="toc-label">// contents</div>
          <ul class="toc-list">
            {tocHeadings.map((h) => (
              <li>
                <a class="toc-link" href={`#${h.slug}`} style={`--toc-depth: ${h.depth - 2};`}>
                  {h.text}
                </a>
              </li>
            ))}
          </ul>
        </>
      )}
    </nav>
  </article>
  <script>
    document.querySelectorAll('.prose pre').forEach((pre) => {
      const btn = document.createElement('button');
      btn.className = 'copy-btn';
      btn.textContent = 'copy';
      btn.setAttribute('aria-label', 'Copy code to clipboard');
      pre.appendChild(btn);

      btn.addEventListener('click', async () => {
        const code = pre.querySelector('code');
        const text = code ? code.innerText : pre.innerText;
        try {
          await navigator.clipboard.writeText(text);
          btn.textContent = 'copied!';
          btn.classList.add('copied');
          setTimeout(() => {
            btn.textContent = 'copy';
            btn.classList.remove('copied');
          }, 2000);
        } catch {
          btn.textContent = 'error';
          setTimeout(() => { btn.textContent = 'copy'; }, 2000);
        }
      });
    });
  </script>
  <script>
  // ── Read time ──────────────────────────────────────────
  const prose = document.querySelector('.prose');
  const metaEl = document.querySelector('.post-meta');

  if (prose && metaEl) {
    const words = (prose.textContent ?? '').trim().split(/\s+/).filter(Boolean).length;
    const mins = Math.max(1, Math.round(words / 200));
    const sep = document.createElement('span');
    sep.className = 'meta-sep';
    sep.setAttribute('aria-hidden', 'true');
    sep.textContent = '·';
    const rt = document.createElement('span');
    rt.className = 'read-time';
    rt.textContent = `${mins} min read`;
    metaEl.appendChild(sep);
    metaEl.appendChild(rt);
  }

  // ── Table of Contents ──────────────────────────────────
  const proseHeadings = Array.from(
    document.querySelectorAll('.prose h2, .prose h3')
  ) as HTMLElement[];
  const tocEl = document.getElementById('toc');

  if (tocEl && tocEl.classList.contains('toc-ready')) {
    // Pre-build a slug→link map so scroll handler does no DOM queries
    const tocLinkMap = new Map<string, Element>();
    for (const a of tocEl.querySelectorAll<HTMLAnchorElement>('a[href^="#"]')) {
      tocLinkMap.set(a.getAttribute('href')!.slice(1), a);
    }

    // Cache heading offsets; refresh on resize (values change when layout reflows)
    let tops = proseHeadings.map(h => h.offsetTop);
    window.addEventListener('resize', () => { tops = proseHeadings.map(h => h.offsetTop); }, { passive: true });

    let prevActive: HTMLElement | null = null;
    function setActiveToc() {
      const scrollY = window.scrollY + 80;
      let active = proseHeadings[0];
      for (let i = 0; i < proseHeadings.length; i++) {
        if (tops[i] <= scrollY) active = proseHeadings[i];
        else break;
      }
      if (active === prevActive) return;
      if (prevActive) tocLinkMap.get(prevActive.id)?.classList.remove('active');
      prevActive = active;
      if (!active.id) return;
      tocLinkMap.get(active.id)?.classList.add('active');
    }
    window.addEventListener('scroll', setActiveToc, { passive: true });
    setActiveToc();
  }
</script>
</BaseLayout>

<style>
  /* Centering wrapper */
  .post {
    max-width: calc(var(--max-content-width) + 300px + 4rem + 2rem);
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  /* Desktop: two-row, two-column grid
     Row 1: post header (left column only)
     Row 2: prose (left) + ToC (right) — both start at the same Y */
  @media (min-width: 1025px) {
    .post {
      display: grid;
      grid-template-columns: 1fr 300px;
      grid-template-areas:
        "header ."
        "prose  toc";
      column-gap: 2rem;
      align-items: start;
    }
    .post-header { grid-area: header; }
    .prose        { grid-area: prose; }
    #toc.toc-ready {
      grid-area: toc;
      margin-top: var(--prose-heading-margin);
    }
  }

  /* Mobile: single column, horizontal padding tightens */
  @media (max-width: 1024px) {
    .post { padding: 3rem 1rem; }
  }

  /* Prevent grid blowout on wide code blocks */
  .prose { max-width: 75ch; min-width: 0; }
  .post-header { margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--color-border-subtle); }
  .post-meta { display: flex; align-items: center; gap: 0.75rem; font-size: 0.8rem; color: var(--color-text-muted); margin-bottom: 1rem; flex-wrap: wrap; }
  .post-title { font-family: var(--font-mono); font-size: 1.75rem; font-weight: 600; line-height: 1.2; margin-bottom: 0.75rem; color: var(--color-text-primary); }
  .post-description { color: var(--color-text-secondary); font-size: 0.95rem; margin-bottom: 1rem; }
  .post-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }

  /* Read time */
  .meta-sep { color: var(--color-border-strong); }
  .read-time { font-family: var(--font-mono); }

  /* Table of Contents — sticky right sidebar, ≥1025px only */
  #toc { display: none; }

  @media (min-width: 1025px) {
    #toc.toc-ready {
      display: block;
      position: sticky;
      top: 4rem;
      height: fit-content;
      border-left: 1px solid var(--color-border-subtle);
      padding-left: 1.25rem;
    }
  }

  .toc-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .toc-list li {
    list-style: none;
  }

  .toc-link {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 0.3rem 0 0.3rem calc(1em + var(--toc-depth, 0) * 0.75rem);
    line-height: 1.4;
    overflow-wrap: break-word;
    transition: color 0.15s, opacity 0.15s;
    opacity: 0.45;
  }
  .toc-link:hover {
    color: var(--color-text-primary);
    text-decoration: none;
    opacity: 0.75;
  }
  .toc-link.active {
    font-weight: 600;
    color: var(--color-text-primary);
    opacity: 1;
  }
</style>
