---
import BaseLayout from './BaseLayout.astro';
import TagBadge from '../components/TagBadge.astro';
import '../styles/prose.css';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  headings?: { depth: number; slug: string; text: string }[];
}

const { title, description, pubDate, updatedDate, tags = [], headings = [] } = Astro.props;
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
const showToc = tocHeadings.length >= 2;
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={title} description={description} ogType="article">
  <article class="post">
    <div class="post-container">
      <header class="post-header">
        <div class="post-meta">
          <time datetime={pubDate.toISOString()}>{fmt(pubDate)}</time>
          {updatedDate && <span class="updated">— updated <time datetime={updatedDate.toISOString()}>{fmt(updatedDate)}</time></span>}
        </div>
        <h1 class="post-title">{title}</h1>
        <p class="post-description">{description}</p>
        {tags.length > 0 && (
          <div class="post-tags">
            {tags.map((tag) => <TagBadge tag={tag} />)}
          </div>
        )}
      </header>
      <div class="prose">
        <slot />
      </div>
    </div>
    <nav id="toc" aria-label="Table of contents" class:list={[{ 'toc-ready': showToc }]}>
      {showToc && (
        <>
          <div class="toc-label">// contents</div>
          <ul class="toc-list">
            {tocHeadings.map((h) => (
              <li>
                <a class:list={['toc-link', { 'toc-h3': h.depth === 3 }]} href={`#${h.slug}`}>
                  {h.text}
                </a>
              </li>
            ))}
          </ul>
        </>
      )}
    </nav>
  </article>
  <script>
    document.querySelectorAll('.prose pre').forEach((pre) => {
      const btn = document.createElement('button');
      btn.className = 'copy-btn';
      btn.textContent = 'copy';
      btn.setAttribute('aria-label', 'Copy code to clipboard');
      pre.appendChild(btn);

      btn.addEventListener('click', async () => {
        const code = pre.querySelector('code');
        const text = code ? code.innerText : pre.innerText;
        try {
          await navigator.clipboard.writeText(text);
          btn.textContent = 'copied!';
          btn.classList.add('copied');
          setTimeout(() => {
            btn.textContent = 'copy';
            btn.classList.remove('copied');
          }, 2000);
        } catch {
          btn.textContent = 'error';
          setTimeout(() => { btn.textContent = 'copy'; }, 2000);
        }
      });
    });
  </script>
  <script>
  // ── Read time ──────────────────────────────────────────
  const prose = document.querySelector('.prose');
  const metaEl = document.querySelector('.post-meta');

  if (prose && metaEl) {
    const words = (prose.textContent ?? '').trim().split(/\s+/).filter(Boolean).length;
    const mins = Math.max(1, Math.round(words / 200));
    const sep = document.createElement('span');
    sep.className = 'meta-sep';
    sep.setAttribute('aria-hidden', 'true');
    sep.textContent = '·';
    const rt = document.createElement('span');
    rt.className = 'read-time';
    rt.textContent = `${mins} min read`;
    metaEl.appendChild(sep);
    metaEl.appendChild(rt);
  }

  // ── Table of Contents ──────────────────────────────────
  const proseHeadings = Array.from(
    document.querySelectorAll('.prose h2, .prose h3')
  ) as HTMLElement[];
  const tocEl = document.getElementById('toc');

  if (tocEl && tocEl.classList.contains('toc-ready')) {
    // Align TOC label with first prose heading — reset first so measurement is clean
    document.fonts.ready.then(() => {
      tocEl!.style.marginTop = '0';
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          if (!proseHeadings[0]) return;
          const tocTop = tocEl!.getBoundingClientRect().top;
          const headingTop = proseHeadings[0].getBoundingClientRect().top;
          tocEl!.style.marginTop = Math.max(0, headingTop - tocTop) + 'px';
          tocEl!.classList.add('toc-visible');
        });
      });
    });

    // Scroll-tracking: highlight the link for the current section
    let prevActive: HTMLElement | null = null;
    function setActiveToc() {
      const scrollY = window.scrollY + 80;
      let active = proseHeadings[0];
      for (const h of proseHeadings) {
        if (h.offsetTop <= scrollY) active = h;
        else break;
      }
      if (active === prevActive) return;
      if (prevActive) {
        const old = tocEl!.querySelector(`a[href="#${prevActive.id}"]`);
        if (old) old.classList.remove('active');
      }
      prevActive = active;
      if (!active.id) return;
      const link = tocEl!.querySelector(`a[href="#${active.id}"]`);
      if (link) link.classList.add('active');
    }
    window.addEventListener('scroll', setActiveToc, { passive: true });
    setActiveToc();
  }
</script>
</BaseLayout>

<style>
  /* Centering wrapper + grid container */
  .post {
    max-width: calc(var(--max-content-width) + 300px + 4rem + 2rem);
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  /* Desktop: two-column grid — content left, ToC right */
  @media (min-width: 1025px) {
    .post {
      display: grid;
      grid-template-columns: 1fr 300px;
      gap: 2rem;
      align-items: start;
    }
  }

  /* Mobile: single column, horizontal padding tightens */
  @media (max-width: 1024px) {
    .post { padding: 3rem 1rem; }
  }

  /* Content column: prevent grid blowout */
  .post-container { min-width: 0; }

  /* Constrain prose text width for comfortable reading */
  .prose { max-width: 75ch; }
  .post-header { margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--color-border-subtle); }
  .post-meta { display: flex; align-items: center; gap: 0.75rem; font-size: 0.8rem; color: var(--color-text-muted); margin-bottom: 1rem; flex-wrap: wrap; }
  .post-title { font-family: var(--font-mono); font-size: 1.75rem; font-weight: 600; line-height: 1.2; margin-bottom: 0.75rem; color: var(--color-text-primary); }
  .post-description { color: var(--color-text-secondary); font-size: 0.95rem; margin-bottom: 1rem; }
  .post-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }

  /* Read time */
  .meta-sep { color: var(--color-border-strong); }
  .read-time { font-family: var(--font-mono); }

  /* Table of Contents — sticky right sidebar, ≥1025px only */
  #toc { display: none; }

  @media (min-width: 1025px) {
    #toc.toc-ready {
      display: block;
      position: sticky;
      top: 4rem;
      height: fit-content;
      border-left: 1px solid var(--color-border-subtle);
      padding-left: 1.25rem;
      opacity: 0;
    }
    #toc.toc-ready.toc-visible {
      opacity: 1;
      transition: opacity 0.15s ease;
    }
  }

  .toc-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .toc-list li {
    list-style: none;
  }

  .toc-link {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 0.3rem 0 0.3rem 1em;
    text-indent: -1em;
    line-height: 1.4;
    overflow-wrap: break-word;
    transition: color 0.15s, opacity 0.15s;
    opacity: 0.45;
  }
  .toc-link:hover {
    color: var(--color-text-primary);
    text-decoration: none;
    opacity: 0.75;
  }
  .toc-link.active {
    font-weight: 600;
    color: var(--color-text-primary);
    opacity: 1;
  }
  .toc-h3 {
    padding-left: calc(1em + 0.75rem);
    text-indent: calc(-1em - 0.75rem);
    font-size: 0.7rem;
  }
</style>
